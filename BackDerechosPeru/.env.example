# ============================================================
# Copia este archivo como .env y completa los valores.
# NO subas .env al repositorio.
# ============================================================

# --- Base de datos (Supabase) ---
# Supabase Studio -> Project Settings -> Database -> Connection string
# Usa el "Connection pooler" (puerto 6543) y reemplaza el driver por asyncpg:
#   postgresql+asyncpg://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Claves de API de Supabase (Settings -> API). Se usarán en Auth/Storage.
# ¡NO pegues las reales aquí! Van en .env (que está en .gitignore).
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key   # SECRETO: nunca subir al repo

# Verificación de JWT (Sprint 2 — auth). Settings -> API -> JWT Secret.
# El backend solo VERIFICA el token que emite Supabase Auth.
SUPABASE_JWT_SECRET=tu-jwt-secret   # SECRETO: nunca subir al repo
# --- App ---
DEBUG=true
CORS_ORIGINS=["http://localhost:4200"]

# --- Embeddings ---
# Proveedor: local (gratis, offline) | openai | fake
# Etapa 1: LOCAL = 100% gratuito, sin claves. La primera ejecución
# descarga el modelo (~120 MB) una sola vez.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# OpenAI / Azure OpenAI (solo si EMBEDDING_PROVIDER=openai):
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://<recurso>.openai.azure.com/openai/deployments/<deployment>
# AZURE_OPENAI_API_VERSION=2024-02-01

# --- Consulta guiada ---
GUIDED_MATCH_COUNT=5
GUIDED_MIN_SIMILARITY=0.25
